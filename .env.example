# Example environment variables (DO NOT commit real secrets)
# Copy to .env and fill values

# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Required for stable tokens across restarts
JWT_SECRET=change_me_to_a_long_random_secret_value

# Optional (default: 86400 = 24 hours)
JWT_ACCESS_TTL_SECONDS=86400

# Optional gateway production controls
GATEWAY_RATE_LIMIT_MAX=500
GATEWAY_RATE_LIMIT_WINDOW_MS=60000
METRICS_TOKEN=

# Optional microservice ports/URLs
TRIPS_SERVICE_URL=http://localhost:4101
PAYMENTS_SERVICE_URL=http://localhost:4102
OPS_SERVICE_URL=http://localhost:4103
AI_SERVICE_URL=http://localhost:4104
SAAS_SERVICE_URL=http://localhost:4105
EVENTS_SERVICE_URL=http://localhost:4106

# SaaS billing webhook and optional auto-cycle
BILLING_WEBHOOK_SECRET=billing-webhook-dev-secret
BILLING_PROVIDER=mockpay
MOCKPAY_CHECKOUT_BASE_URL=https://mockpay.local
SAAS_BILLING_AUTOCYCLE_ENABLED=false
SAAS_BILLING_AUTOCYCLE_CRON=0 1 * * *
SAAS_RECONCILIATION_ENABLED=false
SAAS_RECONCILIATION_CRON=*/30 * * * *

# Expo mobile apps gateway URL
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional: force SSL on/off for Postgres
# DATABASE_SSL=true

# -----------------
# OAuth (Optional)
# -----------------
# These are required if you want passenger login via Google/Apple buttons.
# If not set, the server will keep OAuth endpoints available but return oauth_not_configured.

# Public base URL used to auto-build redirect URIs (recommended in production)
# Example: https://your-domain.com
PUBLIC_BASE_URL=

# Google OAuth (Authorization Code + PKCE)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional override (otherwise derived from PUBLIC_BASE_URL):
# GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/api/oauth/google/callback

# Apple OAuth (Sign in with Apple)
APPLE_OAUTH_CLIENT_ID=
# Option A (static client secret):
APPLE_OAUTH_CLIENT_SECRET=
# Option B (generate client secret from key):
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
APPLE_OAUTH_PRIVATE_KEY=
# Optional override (otherwise derived from PUBLIC_BASE_URL):
# APPLE_OAUTH_REDIRECT_URI=https://your-domain.com/api/oauth/apple/callback
