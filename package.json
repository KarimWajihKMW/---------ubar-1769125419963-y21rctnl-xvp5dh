{
  "name": "akwadra-taxi-app",
  "version": "1.0.0",
  "description": "Taxi booking app with PostgreSQL backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "start:gateway": "node gateway/server.js",
    "start:trips-service": "node services/trips-service/server.js",
    "start:payments-service": "node services/payments-service/server.js",
    "start:ops-service": "node services/ops-service/server.js",
    "start:ai-service": "node services/ai-service/server.js",
    "start:saas-service": "node services/saas-service/server.js",
    "start:events-service": "node services/events-service/server.js",
    "start:micro": "docker compose -f docker-compose.microservices.yml up --build",
    "micro:down": "docker compose -f docker-compose.microservices.yml down",
    "deploy:k8s": "bash scripts/k8s-deploy.sh",
    "sync:secrets:k8s": "bash scripts/k8s-sync-secrets.sh",
    "release:gate": "bash scripts/release-gate.sh",
    "precheck:prod:github": "bash scripts/precheck-production-github-access.sh",
    "trigger:prod:gate": "bash scripts/trigger-production-release-gate.sh",
    "go-live:prod": "bash scripts/go-live-production.sh",
    "readiness:100": "bash scripts/readiness-100.sh",
    "backup:db": "bash scripts/backup-postgres.sh",
    "restore:db": "bash scripts/restore-postgres.sh",
    "test": "node test-runner.js",
    "test:admin-excellence": "node test-admin-excellence.js",
    "test:admin-innovations": "node test-admin-innovations.js",
    "test:admin-executive": "node test-admin-executive.js",
    "test:payment-rating-flow": "node test-payment-rating-flow.js",
    "build": "node -e \"console.log('No build step for this project')\"",
    "preflight:prod": "node scripts/preflight-production.js",
    "smoke:prod": "node scripts/smoke-production.js",
    "verify:admin-innovations": "npm run test:admin-innovations && npm run build",
    "test:gateway": "node scripts/test-gateway.js"
  },
  "keywords": [
    "taxi",
    "booking",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.4",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "openid-client": "^6.7.1",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.1",
    "twilio": "^5.9.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "socket.io-client": "^4.8.1"
  }
}
